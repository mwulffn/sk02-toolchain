#!/bin/bash
# SK02-Build - Compile C to binary for SK-02
# Usage: ./sk02-build program.c [output.bin]

set -e  # Exit on error

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Help message
if [ "$1" == "-h" ] || [ "$1" == "--help" ] || [ -z "$1" ]; then
    echo "SK02-Build - Compile C to binary for SK-02"
    echo ""
    echo "Usage: $0 <input.c> [output.bin]"
    echo ""
    echo "Examples:"
    echo "  $0 program.c              # Creates program.bin"
    echo "  $0 program.c custom.bin   # Creates custom.bin"
    echo ""
    echo "This script will:"
    echo "  1. Compile .c to .asm using sk02cc"
    echo "  2. Assemble .asm to .bin using sk02-asm"
    echo "  3. Clean up intermediate .asm file"
    exit 0
fi

# Get input file
INPUT="$1"

# Check if input file exists
if [ ! -f "$INPUT" ]; then
    echo -e "${RED}Error: File '$INPUT' not found${NC}"
    exit 1
fi

# Check if input is a .c file
if [[ ! "$INPUT" =~ \.c$ ]]; then
    echo -e "${RED}Error: Input must be a .c file${NC}"
    exit 1
fi

# Determine output file
if [ -n "$2" ]; then
    OUTPUT="$2"
else
    # Replace .c with .bin
    OUTPUT="${INPUT%.c}.bin"
fi

# Intermediate .asm file
ASM_FILE="${INPUT%.c}.asm"

echo -e "${YELLOW}Building $INPUT...${NC}"
echo ""

# Step 1: Compile C to assembly
echo -e "${GREEN}[1/2]${NC} Compiling C to assembly..."
if ! uv run sk02cc "$INPUT" -o "$ASM_FILE"; then
    echo -e "${RED}Compilation failed!${NC}"
    exit 1
fi

# Step 2: Assemble to binary
echo -e "${GREEN}[2/2]${NC} Assembling to binary..."
if ! uv run sk02-asm "$ASM_FILE" -o "$OUTPUT"; then
    echo -e "${RED}Assembly failed!${NC}"
    # Clean up intermediate file
    rm -f "$ASM_FILE"
    exit 1
fi

# Success!
echo ""
echo -e "${GREEN}✓ Build successful!${NC}"
echo -e "  Source:  $INPUT"
echo -e "  Output:  $OUTPUT"

# Optional: Show file size
if [ -f "$OUTPUT" ]; then
    SIZE=$(wc -c < "$OUTPUT")
    echo -e "  Size:    $SIZE bytes"
fi

# Ask if user wants to keep .asm file
echo ""
read -p "Keep intermediate assembly file ($ASM_FILE)? [y/N] " -n 1 -r
echo
if [[ ! $REPLY =~ ^[Yy]$ ]]; then
    rm -f "$ASM_FILE"
    echo "Removed $ASM_FILE"
else
    echo "Kept $ASM_FILE"
fi
