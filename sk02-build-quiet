#!/bin/bash
# SK02-Build (Quiet Mode) - Compile C to binary for SK-02 without prompts
# Usage: ./sk02-build-quiet program.c [output.bin]

set -e  # Exit on error

# Check arguments
if [ -z "$1" ]; then
    echo "Usage: $0 <input.c> [output.bin]"
    exit 1
fi

INPUT="$1"
OUTPUT="${2:-${INPUT%.c}.bin}"
ASM_FILE="${INPUT%.c}.asm"

# Compile
uv run sk02cc "$INPUT" -o "$ASM_FILE" || exit 1

# Assemble
uv run sk02-asm "$ASM_FILE" -o "$OUTPUT" || exit 1

# Clean up
rm -f "$ASM_FILE"

echo "Built $OUTPUT"
