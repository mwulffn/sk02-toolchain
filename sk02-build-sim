#!/bin/bash
# SK02-Build-Sim - Compile C directly to simulator text format
# Usage: ./sk02-build-sim program.c [output.txt]

set -e  # Exit on error

# Colors for output
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Check arguments
if [ -z "$1" ]; then
    echo "Usage: $0 <input.c> [output.txt]"
    echo ""
    echo "Compiles C to simulator text format in one step:"
    echo "  1. C → assembly"
    echo "  2. Assembly → binary"
    echo "  3. Binary → simulator format"
    exit 1
fi

INPUT="$1"
OUTPUT="${2:-${INPUT%.c}.txt}"

# Temporary files
ASM_FILE="${INPUT%.c}.asm"
BIN_FILE="${INPUT%.c}.bin"

echo -e "${YELLOW}Building $INPUT for simulator...${NC}"
echo ""

# Step 1: Compile C to assembly
echo -e "${GREEN}[1/3]${NC} Compiling C to assembly..."
if ! uv run sk02cc "$INPUT" -o "$ASM_FILE"; then
    echo "Compilation failed!"
    exit 1
fi

# Step 2: Assemble to binary
echo -e "${GREEN}[2/3]${NC} Assembling to binary..."
if ! uv run sk02-asm "$ASM_FILE" -o "$BIN_FILE"; then
    echo "Assembly failed!"
    rm -f "$ASM_FILE"
    exit 1
fi

# Step 3: Convert to simulator format
echo -e "${GREEN}[3/3]${NC} Converting to simulator format..."
if ! ./bin2sim "$BIN_FILE" -o "$OUTPUT"; then
    echo "Conversion failed!"
    rm -f "$ASM_FILE" "$BIN_FILE"
    exit 1
fi

# Success!
echo ""
echo -e "${GREEN}✓ Build successful!${NC}"
echo "  Source:    $INPUT"
echo "  Simulator: $OUTPUT"

# Show file info
if [ -f "$OUTPUT" ]; then
    LINES=$(wc -l < "$OUTPUT")
    echo "  Lines:     $LINES bytes loaded"
fi

# Clean up intermediate files
rm -f "$ASM_FILE" "$BIN_FILE"
echo ""
echo "Cleaned up intermediate files (.asm, .bin)"
echo "Ready to load into simulator!"
